---
// Home-page lead capture form — sends straight to info@performancemaxagency.com
---

<div class="lead">
  <div class="lead__header">
    <span class="lead__badge">Free Audit</span>
    <h3>Get Your Free Local Visibility Audit</h3>
    <p>Tell us about your business. We'll send a custom audit within 24 hours.</p>
  </div>

  <form class="lead__form" id="lead-form" action="/send.php" method="POST">
    <input type="hidden" name="source" value="audit" />
    <!-- honeypot -->
    <input type="text" name="company_website" tabindex="-1" autocomplete="off" aria-hidden="true" class="lead__hp" />

    <div class="lead__field">
      <input id="lead-name" name="name" type="text" class="input" placeholder="Your name" required />
    </div>
    <div class="lead__field">
      <input id="lead-email" name="email" type="email" class="input" placeholder="Email address" required />
    </div>
    <div class="lead__field">
      <input id="lead-phone" name="phone" type="tel" class="input" placeholder="Phone (optional)" />
    </div>
    <div class="lead__field">
      <input id="lead-business" name="business" type="text" class="input" placeholder="Business name" required />
    </div>
    <div class="lead__field">
      <input id="lead-location" name="location" type="text" class="input" placeholder="City or ZIP" />
    </div>
    <div class="lead__field">
      <select id="lead-service" name="service" class="input">
        <option value="" disabled selected>What do you need help with?</option>
        <option>Near Me Package</option>
        <option>Google Ads</option>
        <option>SEO</option>
        <option>Local SEO</option>
        <option>Social Media</option>
        <option>Lead Generation</option>
        <option>Not sure — need advice</option>
      </select>
    </div>

    <button type="submit" class="btn lead__btn">Get My Free Audit</button>
    <p class="lead__note">No obligation. We reply within 24 hours.</p>
    <p class="lead__success" id="lead-success">Thanks! We'll send your audit within 24 hours.</p>
    <p class="lead__error" id="lead-error"></p>
  </form>
</div>

<style>
  .lead {
    background: var(--glass-bg-strong);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    padding: 1.75rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }
  .lead__header { margin-bottom: 1.25rem; }
  .lead__badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--green);
    background: var(--green-glow);
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    margin-bottom: 0.5rem;
  }
  .lead__header h3 { font-size: 1.2rem; margin-bottom: 0.2rem; }
  .lead__header p { font-size: 0.85rem; color: var(--gray); }

  .lead__form { display: flex; flex-direction: column; gap: 0.6rem; }
  .lead__hp { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
  .lead__btn { width: 100%; margin-top: 0.25rem; }
  .lead__note {
    text-align: center;
    font-size: 0.75rem;
    color: var(--gray-light);
    margin-top: 0.25rem;
  }
  .lead__success,
  .lead__error { display: none; text-align: center; font-size: 0.9rem; font-weight: 600; padding: 0.5rem 0; }
  .lead__success { color: var(--green); }
  .lead__error {
    color: #c0392b;
    font-weight: 500;
    font-size: 0.82rem;
    background: rgba(192, 57, 43, 0.08);
    border: 1px solid rgba(192, 57, 43, 0.2);
    border-radius: var(--radius-sm);
    padding: 0.5rem 0.75rem;
  }

  @media (max-width: 480px) {
    .lead { padding: 1.25rem; }
  }
</style>

<script>
  const lf = document.getElementById('lead-form') as HTMLFormElement | null;
  lf?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = lf.querySelector('button[type="submit"]') as HTMLButtonElement;
    const success = document.getElementById('lead-success') as HTMLElement | null;
    const errorEl = document.getElementById('lead-error') as HTMLElement | null;
    if (errorEl) errorEl.style.display = 'none';

    const original = btn?.textContent || 'Submit';
    if (btn) { btn.textContent = 'Sending…'; btn.disabled = true; btn.style.opacity = '0.6'; }

    try {
      const res = await fetch(lf.action, { method: 'POST', body: new FormData(lf), headers: { Accept: 'application/json' } });
      const data = await res.json().catch(() => ({ success: res.ok }));
      if (res.ok && data.success) {
        lf.querySelectorAll('input, select, textarea, button, .lead__note').forEach((el) => ((el as HTMLElement).style.display = 'none'));
        if (success) success.style.display = 'block';
      } else {
        throw new Error(data.error || 'Something went wrong.');
      }
    } catch (err) {
      if (btn) { btn.textContent = original; btn.disabled = false; btn.style.opacity = '1'; }
      if (errorEl) {
        errorEl.textContent = (err as Error).message + ' Or email info@performancemaxagency.com.';
        errorEl.style.display = 'block';
      }
    }
  });
</script>
