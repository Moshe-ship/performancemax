---
const links = [
  { href: '/services', label: 'Services' },
  { href: '/near-me', label: 'Near Me Package' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<nav class="nav">
  <div class="container nav__inner">
    <a href="/" class="nav__logo">
      <img src="/logo.png" alt="Performance MAX" class="nav__logo-img" />
    </a>
    <div class="nav__right">
      <button class="theme-toggle" id="theme-toggle-mobile" aria-label="Toggle theme">
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      </button>
      <button class="nav__toggle" aria-label="Menu" id="nav-toggle">
        <span></span><span></span><span></span>
      </button>
    </div>
    <ul class="nav__links" id="nav-links">
      {links.map(link => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
      <li><a href="/contact" class="btn btn--sm">Get a Free Audit</a></li>
      <li class="nav__theme-desktop">
        <button class="theme-toggle" id="theme-toggle-desktop" aria-label="Toggle theme">
          <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </button>
      </li>
    </ul>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    background: var(--nav-bg);
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    border-bottom: 1px solid var(--border);
    z-index: 100;
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4.5rem;
  }
  .nav__logo { flex-shrink: 0; }
  .nav__logo-img {
    height: 44px;
    width: auto;
  }
  :global([data-theme="dark"]) .nav__logo-img {
    filter: brightness(0) invert(1);
  }
  .nav__right {
    display: none;
    align-items: center;
    gap: 0.75rem;
  }

  /* Nav links */
  .nav__links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    list-style: none;
    font-size: 0.85rem;
    font-weight: 500;
  }
  .nav__links a { transition: color 0.2s; }
  .nav__links a:hover { color: var(--green); }
  .btn--sm {
    padding: 0.45rem 1.1rem;
    font-size: 0.8rem;
  }

  /* Theme toggle */
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    cursor: pointer;
    color: var(--navy);
    transition: all 0.2s;
  }
  .theme-toggle:hover {
    border-color: var(--green);
    color: var(--green);
  }
  .icon-sun { display: none; }
  .icon-moon { display: block; }
  :global([data-theme="dark"]) .icon-sun { display: block; }
  :global([data-theme="dark"]) .icon-moon { display: none; }

  .nav__theme-desktop {
    display: list-item;
  }

  /* Mobile hamburger */
  .nav__toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .nav__toggle span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--navy);
    border-radius: 2px;
    transition: all 0.2s;
  }

  @media (max-width: 768px) {
    .nav__inner { height: 4rem; }
    .nav__logo-img { height: 36px; }
    .nav__right { display: flex; }
    .nav__toggle { display: flex; }
    .nav__theme-desktop { display: none; }
    .nav__links {
      display: none;
      position: absolute;
      top: 4rem;
      left: 0;
      right: 0;
      background: var(--nav-bg);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      flex-direction: column;
      padding: 1.5rem;
      gap: 1rem;
      border-bottom: 1px solid var(--border);
      box-shadow: var(--shadow-lg);
    }
    .nav__links.open { display: flex; }
  }
</style>

<script>
  document.getElementById('nav-toggle')?.addEventListener('click', () => {
    document.getElementById('nav-links')?.classList.toggle('open');
  });

  function toggleTheme() {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  }

  document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-desktop')?.addEventListener('click', toggleTheme);
</script>
