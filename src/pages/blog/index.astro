---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sorted = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Base title="Blog" description="Local business marketing insights — SEO, Google Ads, local search strategies, and industry updates.">

  <section class="page-header">
    <div class="container">
      <h1>Blog</h1>
      <p>Practical strategies and insights for local business owners who want to grow online.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {sorted.length === 0 && <p style="color:var(--gray)">Coming soon.</p>}
      <div class="blog-list">
        {sorted.map(post => (
          <a href={`/blog/${post.id}`} class="blog-item">
            {post.data.image && <img src={post.data.image} alt="" class="blog-item__img" loading="lazy" />}
            <div class="blog-item__inner">
              <span class="blog-item__date">{post.data.date}</span>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
            </div>
            <span class="blog-item__arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

</Base>

<style>
  .blog-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
  }
  .blog-item__img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    border-radius: var(--radius) var(--radius) 0 0;
  }
  .blog-item {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0;
    padding: 0;
    background: var(--glass-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    transition: all 0.3s ease;
  }
  .blog-item:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
    border-color: rgba(124, 179, 66, 0.2);
  }
  .blog-item__date {
    font-size: 0.75rem;
    color: var(--gray-light);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .blog-item h2 {
    font-size: 1.15rem;
    margin: 0.2rem 0 0.15rem;
  }
  .blog-item p {
    font-size: 0.85rem;
    color: var(--gray);
    line-height: 1.5;
    padding: 0 1.25rem 1.25rem;
  }
  .blog-item__date {
    padding: 1.25rem 1.25rem 0;
  }
  .blog-item h2 {
    padding: 0 1.25rem;
  }
  .blog-item__arrow { display: none; }

  @media (max-width: 768px) {
    .blog-list { grid-template-columns: 1fr; }
  }
</style>
